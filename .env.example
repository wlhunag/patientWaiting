# Google Calendar API
# 取得方式：Google Cloud Console → APIs & Services → Credentials → Create API Key
GOOGLE_CALENDAR_API_KEY=

# 你的牙科行事曆 ID（看起來像 xxxxxxxx@group.calendar.google.com）
GOOGLE_CALENDAR_ID=

# 助理端的隨機網址（不要讓病人猜得到），自己想一串長字串
STAFF_SECRET_PATH=change-me-to-a-long-random-string

# Upstash Redis（從 Upstash console 取得，直接複製貼上即可）
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# 註：部署到 Vercel 時，如果你用 Vercel 內建的 KV，也可以改用下面這對變數名
# KV_REST_API_URL=
# KV_REST_API_TOKEN=

# 時區（台灣固定）
TZ=Asia/Taipei
